# ITF Corporate Scorecard — Environment Variables
# Copy this file to `.env` and fill in the values from your Supabase project
# (Project Settings → API).

# ---- Client (exposed to the browser via Vite) ----
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"        # publishable / anon key
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# ---- Server (used only by server functions / SSR) ----
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Service role key — REQUIRED only if you deploy the `bootstrap-admin`
# edge function or run privileged server tasks. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_xxx"
